<apex:page controller="FinancialReportController" renderAs="pdf" applyBodyTag="false" showHeader="false">
    <head>
        <style type="text/css">
            @page {
                margin: 0.5in;
                size: letter;
            }

            body { 
                font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; 
                font-size: 11px; 
                color: #000; 
                line-height: 1.3;
            }

            /* --- HEADER LAYOUT --- */
            .header-layout { width: 100%; margin-bottom: 20px; }
            .header-layout td { vertical-align: top; }
            .logo { max-height: 80px; width: auto; }

            /* --- TOP RIGHT INFO TABLE --- */
            .info-table { 
                width: 250px; 
                border-collapse: collapse; 
                float: right; 
                border: 1px solid #000;
            }
            .info-table th { background-color: #444; color: #fff; font-weight: bold; text-align: center; padding: 4px; border: 1px solid #000; font-size: 12px; }
            .info-table td { padding: 4px 6px; border: 1px solid #000; background-color: #f9f9f9; }
            .info-label { font-weight: bold; width: 40%; }

            /* --- MAIN REPORT TITLE --- */
            .report-title {
                font-size: 18px; font-weight: bold; text-align: center; margin-top: 10px; margin-bottom: 10px; clear: both;
            }

            /* --- FINANCIAL TABLES --- */
            .data-table { 
                width: 100%; border-collapse: collapse; margin-bottom: 10px; border: 1px solid #000;
            }
            .table-main-header { 
                background-color: #444; color: #fff; text-align: center; text-transform: uppercase; font-weight: bold; padding: 6px; font-size: 12px; border: 1px solid #000;
            }
            .table-sub-header {
                background-color: #666; color: #fff; text-align: center; font-weight: bold; padding: 4px; border: 1px solid #000;
            }
            .data-table th, .data-table td { border: 1px solid #000; padding: 4px 6px; }
            .data-table th { background-color: #eee; text-align: left; font-weight: bold; }
            .data-table td.col-right { text-align: right; font-weight: bold; width: 30%; }
            .data-table td.col-left { text-align: left; }
            
            .row-total { background-color: #e0e0e0; font-weight: bold; }

            /* --- RATIO BOXES --- */
            .ratio-layout { width: 100%; margin-top: 15px; text-align: center; border-collapse: separate; border-spacing: 15px 0; }
            .ratio-box {
                border: 2px solid #666;
                border-radius: 6px;
                background-color: #f0f0f0;
                padding: 15px;
                text-align: center;
                height: 60px;
            }
            .ratio-title { font-size: 14px; font-weight: bold; margin-bottom: 8px; }
            .ratio-value { font-size: 24px; font-weight: bold; color: #000; }

            /* --- FOOTER --- */
            .footer-notes { margin-top: 20px; border-top: 2px solid #000; padding-top: 8px; text-align: center; }
            .footer-notes p { margin: 3px 0; font-size: 11px; }
            .confidential { font-size: 12px; font-weight: bold; text-transform: uppercase; margin-top: 10px !important;}
        </style>
    </head>
    <body>
        
        <!-- HEADER LAYOUT -->
        <table class="header-layout">
            <tr>
                <td style="width: 50%;">
                    <apex:image url="{!$Resource.Nexus_Logo}" styleClass="logo" />
                </td>
                <td style="width: 50%;">
                    <table class="info-table">
                        <tr><th>Report Metric</th><th>Data</th></tr>
                        <tr><td class="info-label">Application ID</td><td>{!app.Name}</td></tr>
                        <tr><td class="info-label">Account</td><td>{!app.Account__r.Name}</td></tr>
                        <tr><td class="info-label">Status</td><td>{!app.Status__c}</td></tr>
                        <tr><td class="info-label">Report Date</td><td><apex:outputText value="{0,date,MMMM d, yyyy}"><apex:param value="{!TODAY()}"/></apex:outputText></td></tr>
                    </table>
                </td>
            </tr>
        </table>

        <div class="report-title">Nexus LME: PNWS Standard Financial Overview &amp; Snapshot</div>

        <!-- 1. FINANCIAL SUMMARY -->
        <table class="data-table">
            <tr><td colspan="2" class="table-main-header">FINANCIAL SUMMARY</td></tr>
            <tr><td class="table-sub-header">Financial Metric</td><td class="table-sub-header">Amount (INR)</td></tr>
            <tr><th>Total Monthly Income</th><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalMonthlyIncome}"/></apex:outputText></td></tr>
            <tr><th>Total Estimated Assets</th><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalEstimatedAssets}"/></apex:outputText></td></tr>
            <tr><th>Total Monthly Liabilities</th><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalMonthlyLiabilities}"/></apex:outputText></td></tr>
            <tr><th>Total Outstanding Debt Owed</th><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalOutstandingDebt}"/></apex:outputText></td></tr>
        </table>

        <!-- 2. ANALYSIS OF KEY FINANCIAL COMPONENTS -->
        <table class="data-table">
            <tr><td colspan="3" class="table-main-header">ANALYSIS OF KEY FINANCIAL COMPONENTS</td></tr>
            
            <!-- INCOME DETAILS -->
            <tr><td colspan="3" class="table-sub-header">Comprehensive Income Analysis</td></tr>
            <tr><th colspan="2">Income Source</th><th>Amount (Monthly)</th></tr>
            <apex:repeat value="{!incomes}" var="inc">
                <tr><td colspan="2" class="col-left">{!inc.Income_Source__c}</td><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!inc.Monthly_Amount__c}"/></apex:outputText></td></tr>
            </apex:repeat>
            <tr class="row-total"><td colspan="2" class="col-left">Total Monthly Income</td><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalMonthlyIncome}"/></apex:outputText></td></tr>

            <!-- ASSET DETAILS -->
            <tr><td colspan="3" class="table-sub-header">Asset Valuation Detail</td></tr>
            <tr><th colspan="2">Key Assets</th><th>Estimated Value</th></tr>
            <apex:repeat value="{!assets}" var="ast">
                <tr><td colspan="2" class="col-left">{!ast.Asset_Type__c}</td><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!ast.Estimated_Value__c}"/></apex:outputText></td></tr>
            </apex:repeat>
            <tr class="row-total"><td colspan="2" class="col-left">Total Estimated Value</td><td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalEstimatedAssets}"/></apex:outputText></td></tr>

            <!-- DEBT DETAILS -->
            <tr><td colspan="3" class="table-sub-header">Debt Obligations Analysis</td></tr>
            <tr><th style="width: 40%;">Key Debts</th><th style="width: 30%;">Amount (Monthly Obligation)</th><th style="width: 30%;">Total Debt Owed</th></tr>
            <apex:repeat value="{!liabilities}" var="liab">
                <tr>
                    <td class="col-left">{!liab.Liability_Type__c}</td>
                    <td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!liab.Monthly_Payment__c}"/></apex:outputText></td>
                    <td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!liab.Amount_Owed__c}"/></apex:outputText></td>
                </tr>
            </apex:repeat>
            <tr class="row-total">
                <td class="col-left">Total Debt Owed</td>
                <td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalMonthlyLiabilities}"/></apex:outputText></td>
                <td class="col-right">₹<apex:outputText value="{0,number,###,###,##0.00}"><apex:param value="{!totalOutstandingDebt}"/></apex:outputText></td>
            </tr>
        </table>

        <!-- IDENTICAL RATIO BOXES -->
        <table class="ratio-layout">
            <tr>
                <td style="width: 50%;">
                    <div class="ratio-box">
                        <div class="ratio-title">DTI Ratio:</div>
                        <div class="ratio-value">
                            <apex:outputText rendered="{!dtiRatio != null}" value="{0,number,0.00}%"><apex:param value="{!dtiRatio}"/></apex:outputText>
                            <apex:outputText rendered="{!dtiRatio == null}" value="N/A"/>
                        </div>
                    </div>
                </td>
                <td style="width: 50%;">
                    <div class="ratio-box">
                        <div class="ratio-title">Asset/Liability Ratio:</div>
                        <div class="ratio-value">
                            <apex:outputText rendered="{!assetLiabilityRatio != null}" value="{0,number,0.00}"><apex:param value="{!assetLiabilityRatio}"/></apex:outputText>
                            <apex:outputText rendered="{!assetLiabilityRatio == null}" value="N/A"/>
                        </div>
                    </div>
                </td>
            </tr>
        </table>

        <!-- FOOTER -->
        <div class="footer-notes">
            <p><i>Note: This report provides a summation of aggregated related borrower financials calculated<br/>automatically upon application submission.</i></p>
            <p class="confidential">CONFIDENTIAL - FOR INTERNAL UNDERWRITING USE ONLY</p>
        </div>

    </body>
</apex:page>